# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Resend (email API) ────────────────────────────────────────────────────────
# Get this from resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# Must be an address on a domain you've verified in Resend (Domains tab).
# Before verifying a domain, you can only use onboarding@resend.dev and can
# only send TO the email address on your Resend account.
EMAIL_FROM="Portfolio <contact@yourdomain.com>"

# The inbox that receives contact form submissions
RECIPIENT_EMAIL=your-address@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed Vercel URL in production, localhost for local dev
FRONTEND_ORIGIN=http://localhost:3000
