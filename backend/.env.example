# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Outlook / Microsoft 365 SMTP ──────────────────────────────────────────────
#
# Personal Outlook (@outlook.com / @hotmail.com / @live.com)
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
#
# Microsoft 365 work/school account — change host to:
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
#
EMAIL_USER=your-address@outlook.com
EMAIL_PASS=your_app_password_here

# ── Recipient ─────────────────────────────────────────────────────────────────
# The inbox that receives contact form submissions (usually same as EMAIL_USER)
RECIPIENT_EMAIL=your-address@outlook.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Change to your production domain when deploying
FRONTEND_ORIGIN=http://localhost:3000
